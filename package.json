{
  "name": "odice",
  "version": "0.11.2",
  "private": true,
  "description": "ODICE — Outil de Décision pour les mouvements de viandes en contexte de Peste Porcine Africaine",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "serve -s dist -l tcp://0.0.0.0:${PORT:-3000}",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fixture:abattoirs": "node scripts/extract-abattoirs-fixture.ts",
    "fixture:abattoirs:check": "node scripts/extract-abattoirs-fixture.ts --check",
    "fixture:etablissements": "node scripts/extract-etablissements-fixture.ts",
    "fixture:etablissements:check": "node scripts/extract-etablissements-fixture.ts --check",
    "fixture:check": "pnpm fixture:abattoirs:check && pnpm fixture:etablissements:check",
    "validate": "pnpm format && pnpm lint:fix && pnpm typecheck && pnpm fixture:check && pnpm test",
    "validate:full": "pnpm validate && pnpm test:e2e"
  },
  "dependencies": {
    "@gouvfr/dsfr": "^1.14.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "serve": "^14.2.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "xlsx": "^0.18.5"
  }
}
